GUI/
examples/samples/


# ----------------------------------------------------
# Ignore compiled executables in examples
# ----------------------------------------------------
# Common named executables produced by examples build
examples/multisphere_app
examples/multisphere_collision
examples/multisphere_mesh
# Common binary extensions
examples/*.exe
examples/*.out
examples/*.bin
examples/*.so
examples/*.dll
examples/*.vtk
examples/*.csv

# ----------------------------------------------------
# Ignore any folder in `examples/` that contains the word "output"
# and all files inside that folder (any depth)
# ----------------------------------------------------
# Matches: examples/output_mesh_example/, examples/some_output_dir/, examples/foo_output_bar/
examples/**/*output*/
examples/**/*output*/**


src/batch_multisphere.cpp
