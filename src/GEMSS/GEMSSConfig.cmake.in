@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Consuming projects need to find Eigen3 because GEMSS depends on it
find_dependency(Eigen3)

# If GEMSS was compiled with OpenMP, consuming projects must also find it
set(GEMSS_USE_OPENMP @GEMSS_USE_OPENMP@)
if(GEMSS_USE_OPENMP)
    find_dependency(OpenMP)
endif()

# Include the auto-generated targets file
include("${CMAKE_CURRENT_LIST_DIR}/GEMSSTargets.cmake")